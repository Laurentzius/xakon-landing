---
import "../styles/global.css";
import Hero from "../components/Hero.astro";
import Projects from "../components/Projects.astro";
import Contact from "../components/Contact.astro";
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Xakon — студия веб-разработки. Портфолио проектов." />
    <title>Xakon — Web Development Studio</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script>
      (function(){
        var t=localStorage.getItem("theme");
        if(!t) t=window.matchMedia("(prefers-color-scheme:dark)").matches?"dark":"light";
        document.documentElement.setAttribute("data-theme",t);
      })();
    </script>
  </head>
  <body>
    <!-- Custom cursor element -->
    <div class="cursor" aria-hidden="true"></div>

    <Hero />
    <Projects />
    <Contact />

    <footer class="footer">
      <div class="container">
        <span class="footer-text">© {new Date().getFullYear()} XAKON</span>
      </div>
    </footer>
  </body>
</html>

<script>
  /* ── Smooth cursor ── */
  (function() {
    const cursor = document.querySelector(".cursor");
    if (!cursor) return;

    let mx = -100, my = -100;
    let cx = -100, cy = -100;

    document.addEventListener("mousemove", (e) => {
      mx = e.clientX;
      my = e.clientY;
    });

    function lerp(a, b, t) { return a + (b - a) * t; }

    function animate() {
      cx = lerp(cx, mx, 0.15);
      cy = lerp(cy, my, 0.15);
      cursor.style.transform = `translate(${cx}px, ${cy}px)`;
      requestAnimationFrame(animate);
    }

    animate();

    document.addEventListener("mouseenter", () => { cursor.style.opacity = 1; });
    document.addEventListener("mouseleave", () => { cursor.style.opacity = 0; });
  })();

  /* ── Parallax scroll ── */
  (function() {
    const layers = [
      { sel: ".hero-decor .hero-circle--red", speed: 0.15 },
      { sel: ".hero-decor .hero-circle--blue", speed: -0.2 },
      { sel: ".hero-decor .hero-circle--yellow", speed: 0.25 },
      { sel: ".hero-decor .hero-blob", speed: -0.12 },
      { sel: ".hero-decor .hero-grid", speed: 0.1 },
      { sel: ".hero-decor .hero-dots", speed: -0.08 },
      { sel: ".hero-decor .hero-squiggle", speed: 0.18 },
      { sel: ".hero-decor .hero-zigzag", speed: -0.15 },
      { sel: ".contact-decor .contact-circle", speed: -0.2 },
      { sel: ".contact-decor .contact-squiggle", speed: 0.15 },
    ];

    const els = layers.map(l => {
      const el = document.querySelector(l.sel);
      return el ? { el, speed: l.speed } : null;
    }).filter(Boolean);

    if (!els.length) return;

    function update() {
      const sy = window.scrollY;
      const vh = window.innerHeight;
      els.forEach(({ el, speed }) => {
        const rect = el.getBoundingClientRect();
        const center = rect.top + rect.height / 2;
        const progress = (center - vh * 0.5) / vh;
        el.style.marginTop = `${progress * vh * speed * 0.3}px`;
      });
    }

    let ticking = false;
    window.addEventListener("scroll", () => {
      if (!ticking) {
        requestAnimationFrame(() => { update(); ticking = false; });
        ticking = true;
      }
    });
    update();

  /* ── Section scroll (one section per wheel tick) ── */
  (function() {
    var SECTIONS = [
      document.querySelector(".hero"),
      document.querySelector(".projects"),
      document.querySelector(".contact"),
    ].filter(Boolean);
    if (SECTIONS.length < 2) return;

    var cur = 0;
    var locked = false;

    function getCur() {
      var best = 0, bestDist = Infinity;
      SECTIONS.forEach(function(s, i) {
        var t = Math.abs(s.getBoundingClientRect().top);
        if (t < bestDist) { bestDist = t; best = i; }
      });
      return best;
    }

    function goTo(idx) {
      if (idx === cur) return;
      cur = idx;
      locked = true;
      SECTIONS[idx].scrollIntoView({ behavior: "smooth", block: "start" });
      setTimeout(function() { locked = false; }, 900);
    }

    window.addEventListener("wheel", function(e) {
      var inCar = e.target.closest && e.target.closest("#projects-carousel");
      if (inCar && Math.abs(e.deltaX) > Math.abs(e.deltaY)) return;
      if (locked) { e.preventDefault(); return; }
      var dir = e.deltaY > 0 ? 1 : -1;
      var next = cur + dir;
      if (next < 0 || next >= SECTIONS.length) return;
      e.preventDefault();
      goTo(next);
    }, { passive: false });

    window.addEventListener("scroll", function() {
      if (!locked) cur = getCur();
    }, { passive: true });

    cur = getCur();
  })();
  })();


</script>

<style>
  .footer {
    padding: 24px 0;
    background: var(--black);
    color: var(--white);
    text-align: center;
  }

  .footer-text {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  /* ── Custom cursor ── */
  .cursor {
    position: fixed;
    width: 24px;
    height: 24px;
    border: 2px solid var(--black);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-100px, -100px);
    transition: opacity 0.3s ease, width 0.3s ease, height 0.3s ease, border-color 0.3s ease;
    mix-blend-mode: difference;
    opacity: 0;
  }

  /* Hide default cursor on interactive elements */
  a, button {
    cursor: none;
  }
</style>
