---
import "../styles/global.css";
import Hero from "../components/Hero.astro";
import Projects from "../components/Projects.astro";
import Contact from "../components/Contact.astro";
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Xakon — студия веб-разработки. Портфолио проектов." />
    <title>Xakon — Web Development Studio</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script>
      (function(){
        var t=localStorage.getItem("theme");
        if(!t) t=window.matchMedia("(prefers-color-scheme:dark)").matches?"dark":"light";
        document.documentElement.setAttribute("data-theme",t);
      })();
    </script>
  </head>
  <body>
    <!-- Custom cursor elements -->
    <div class="cursor-dot" aria-hidden="true"></div>
    <div class="cursor-ring" aria-hidden="true"></div>
    <Hero />
    <Projects />
    <Contact />

    <footer class="footer">
      <div class="container">
        <span class="footer-text">© {new Date().getFullYear()} XAKON</span>
      </div>
    </footer>
  </body>
</html>

<script>
  /* ── Smooth cursor (dot + ring) ── */
  (function() {
    var dot = document.querySelector(".cursor-dot");
    var ring = document.querySelector(".cursor-ring");
    if (!dot || !ring) return;

    var mx = -100, my = -100;
    var dx = -100, dy = -100;
    var rx = -100, ry = -100;
    var hoverEl = null;

    document.addEventListener("mousemove", function(e) {
      mx = e.clientX;
      my = e.clientY;
    });

    function lerp(a, b, t) { return a + (b - a) * t; }

    function animate() {
      dx = lerp(dx, mx, 0.2);
      dy = lerp(dy, my, 0.2);
      rx = lerp(rx, mx, 0.08);
      ry = lerp(ry, my, 0.08);
      dot.style.left = dx + "px";
      dot.style.top = dy + "px";
      ring.style.left = rx + "px";
      ring.style.top = ry + "px";
      requestAnimationFrame(animate);
    }
    animate();

    document.addEventListener("mouseenter", function() {
      dot.style.opacity = 1;
      ring.style.opacity = 1;
    });
    document.addEventListener("mouseleave", function() {
      dot.style.opacity = 0;
      ring.style.opacity = 0;
    });

    /* ── Hover effect on interactive elements ── */
    var INTERACTIVE = 'a, button, [role="button"], .carousel-btn, .contact-link';

    document.addEventListener("mouseover", function(e) {
      var t = e.target.closest(INTERACTIVE);
      if (t !== hoverEl) {
        hoverEl = t;
        if (t) {
          ring.classList.add("cursor-ring--hover");
          dot.classList.add("cursor-dot--hover");
        } else {
          ring.classList.remove("cursor-ring--hover");
          dot.classList.remove("cursor-dot--hover");
        }
      }
    });
  })();

  /* ── Parallax scroll ── */
  (function() {
    const layers = [
      { sel: ".hero-decor .hero-circle--red", speed: 0.15 },
      { sel: ".hero-decor .hero-circle--blue", speed: -0.2 },
      { sel: ".hero-decor .hero-circle--yellow", speed: 0.25 },
      { sel: ".hero-decor .hero-blob", speed: -0.12 },
      { sel: ".hero-decor .hero-grid", speed: 0.1 },
      { sel: ".hero-decor .hero-dots", speed: -0.08 },
      { sel: ".hero-decor .hero-squiggle", speed: 0.18 },
      { sel: ".hero-decor .hero-zigzag", speed: -0.15 },
      { sel: ".contact-decor .contact-circle", speed: -0.2 },
      { sel: ".contact-decor .contact-squiggle", speed: 0.15 },
    ];

    const els = layers.map(l => {
      const el = document.querySelector(l.sel);
      return el ? { el, speed: l.speed } : null;
    }).filter(Boolean);

    if (!els.length) return;

    function update() {
      const sy = window.scrollY;
      const vh = window.innerHeight;
      els.forEach(({ el, speed }) => {
        const rect = el.getBoundingClientRect();
        const center = rect.top + rect.height / 2;
        const progress = (center - vh * 0.5) / vh;
        el.style.marginTop = `${progress * vh * speed * 0.3}px`;
      });
    }

    let ticking = false;
    window.addEventListener("scroll", () => {
      if (!ticking) {
        requestAnimationFrame(() => { update(); ticking = false; });
        ticking = true;
      }
    });
    update();

  /* ── Section scroll (one section per wheel tick) ── */
  (function() {
    var SECTIONS = [
      document.querySelector(".hero"),
      document.querySelector(".projects"),
      document.querySelector(".contact"),
    ].filter(Boolean);
    if (SECTIONS.length < 2) return;

    var cur = 0;
    var locked = false;

    function getCur() {
      var best = 0, bestDist = Infinity;
      SECTIONS.forEach(function(s, i) {
        var t = Math.abs(s.getBoundingClientRect().top);
        if (t < bestDist) { bestDist = t; best = i; }
      });
      return best;
    }

    function goTo(idx) {
      if (idx === cur) return;
      cur = idx;
      locked = true;
      SECTIONS[idx].scrollIntoView({ behavior: "smooth", block: "start" });
      setTimeout(function() { locked = false; }, 900);
    }

    window.addEventListener("wheel", function(e) {
      var inCar = e.target.closest && e.target.closest("#projects-carousel");
      if (inCar && Math.abs(e.deltaX) > Math.abs(e.deltaY)) return;
      if (locked) { e.preventDefault(); return; }
      var dir = e.deltaY > 0 ? 1 : -1;
      var next = cur + dir;
      if (next < 0 || next >= SECTIONS.length) return;
      e.preventDefault();
      goTo(next);
    }, { passive: false });

    window.addEventListener("scroll", function() {
      if (!locked) cur = getCur();
    }, { passive: true });

    cur = getCur();
  })();
  })();


</script>

<style>
  .footer {
    padding: 24px 0;
    background: var(--black);
    color: var(--white);
    text-align: center;
  }

  .footer-text {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  /* ── Custom cursor (dot + ring) ── */

  .cursor-dot,
  .cursor-ring {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    left: 0;
    top: 0;
    transform: translate(-50%, -50%);
    transition: opacity 0.3s ease;
  }

  .cursor-dot {
    width: 6px;
    height: 6px;
    background: var(--black);
    z-index: 10000;
    transition: opacity 0.3s ease, width 0.3s ease, height 0.3s ease;
    mix-blend-mode: difference;
    opacity: 0;
  }

  .cursor-dot--hover {
    width: 10px;
    height: 10px;
  }

  .cursor-ring {
    width: 34px;
    height: 34px;
    border: 1.5px solid var(--black);
    z-index: 9999;
    transition: opacity 0.3s ease, width 0.4s ease, height 0.4s ease, border-color 0.3s ease, background 0.3s ease;
    mix-blend-mode: difference;
    opacity: 0;
  }

  .cursor-ring--hover {
    width: 54px;
    height: 54px;
    background: rgba(255, 190, 11, 0.1);
  }

  /* Hide default cursor */
  a, button, [role="button"] {
    cursor: none;
  }
</style>
