---

<section class="contact" id="contact">
  <!-- Decorative band at top -->
  <div class="contact-band-top" aria-hidden="true"></div>

  <div class="container">
    <div class="contact-layout">
      <div class="contact-info fade-in">
        <span class="section-label">/ Contact</span>
        <h2 class="section-title">Связаться</h2>
        <p class="section-desc">
          Открыт к предложениям, коллаборациям и новым проектам.
          Пиши в Telegram или на почту.
        </p>
      </div>

      <div class="contact-links">
        {links.map((link, i) => (
          <a href={link.url} class="contact-link fade-in" style={`animation-delay: ${0.15 * i}s`}>

            <span class="contact-link-icon" set:html={link.icon}></span>
            <span class="contact-link-name">{link.name}</span>
            <span class="contact-link-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Decorative animated elements -->
  <div class="contact-decor" aria-hidden="true">
    <div class="contact-circle contact-circle--blue" data-decor></div>
    <div class="contact-circle contact-circle--red" data-decor></div>
    <div class="contact-circle contact-circle--yellow" data-decor></div>

    <svg class="contact-squiggle" data-decor viewBox="0 0 200 30">
      <defs>
        <linearGradient id="contact-squiggle-grad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="var(--blue)" />
          <stop offset="50%" stop-color="var(--green)" />
          <stop offset="100%" stop-color="var(--yellow)" />
        </linearGradient>
      </defs>
      <path
        d="M0 15 Q25 0 50 15 T100 15 T150 15 T200 15"
        fill="none"
        stroke="url(#contact-squiggle-grad)"
        stroke-width="3"
        opacity="0.22"
      />
    </svg>

    <div class="contact-dots" data-decor></div>

    <svg class="contact-zigzag" data-decor viewBox="0 0 180 70">
      <defs>
        <linearGradient id="contact-zigzag-grad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="var(--green)" />
          <stop offset="50%" stop-color="var(--blue)" />
          <stop offset="100%" stop-color="var(--purple)" />
        </linearGradient>
      </defs>
      <polyline
        points="0,70 22,0 45,70 67,0 90,70 112,0 135,70 157,0 180,70"
        fill="none"
        stroke="url(#contact-zigzag-grad)"
        stroke-width="4"
        opacity="0.22"
      />
    </svg>

    <div class="contact-blob" data-decor aria-hidden="true"></div>
  </div>

  <div class="contact-band-bottom" aria-hidden="true"></div>
</section>
<style>
  .contact {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding: 100px 0 80px;
    position: relative;
    background: var(--white);
  }

  .contact-band-top {
    width: 100%;
    height: 8px;
    background: repeating-linear-gradient(
      90deg,
      var(--black) 0px,
      var(--black) 15px,
      var(--pink) 15px,
      var(--pink) 30px,
      var(--blue) 30px,
      var(--blue) 45px
    );
    background-size: 45px 8px;
    animation: hue-shift 3s steps(6) infinite;
    position: absolute;
    top: 0;
    left: 0;
  }

  .contact-band-bottom {
    width: 100%;
    height: 12px;
    background: repeating-linear-gradient(
      90deg,
      var(--green) 0px,
      var(--green) 12px,
      var(--yellow) 12px,
      var(--yellow) 24px,
      var(--black) 24px,
      var(--black) 36px
    );
    background-size: 36px 12px;
    animation: hue-shift 5s steps(6) infinite reverse;
    position: absolute;
    bottom: 0;
    left: 0;
  }
  .contact-decor {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* ── Interactive Shapes Hover ── */
  .contact-circle,
  .contact-squiggle,
  .contact-zigzag,
  .contact-blob,
  .contact-dots {
    cursor: pointer;
    pointer-events: auto;
    transition: scale 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                filter 0.3s ease, 
                opacity 0.3s ease;
  }

  .contact-squiggle,
  .contact-zigzag {
    filter: blur(1.5px);
  }

  .contact-squiggle:hover,
  .contact-zigzag:hover,
  .contact-squiggle.decor-active,
  .contact-zigzag.decor-active {
    scale: 1.18;
    opacity: 0.45 !important;
    filter: blur(1px) saturate(1.5);
  }

  .contact-dots {
    filter: blur(1px);
  }

  .contact-dots:hover,
  .contact-dots.decor-active {
    scale: 1.08;
    opacity: 0.3 !important;
    filter: blur(0.5px) saturate(1.5);
  }

  .contact-circle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.1;
    filter: blur(3px);
    transition: scale 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                filter 0.3s ease, 
                opacity 0.3s ease;
  }

  .contact-circle:hover,
  .contact-circle.decor-active {
    animation-play-state: paused;
    scale: 1.18;
    opacity: 0.45 !important;
    filter: blur(3px) saturate(1.5) contrast(1.1);
  }

  .contact-circle--blue {
    width: 200px;
    height: 200px;
    background: radial-gradient(circle at 30% 30%, var(--blue) 0%, var(--purple) 45%, var(--pink) 100%);
    top: 20%;
    right: -60px;
    animation: float-complex 18s ease-in-out infinite, color-drift-circle 10s linear infinite;
  }

  .contact-circle--red {
    width: 140px;
    height: 140px;
    background: radial-gradient(circle at 30% 30%, var(--red) 0%, var(--pink) 45%, var(--orange) 100%);
    bottom: 15%;
    left: -40px;
    animation: float-complex 20s ease-in-out infinite reverse, color-drift-circle 10s linear infinite reverse;
    opacity: 0.08;
  }

  .contact-circle--yellow {
    width: 90px;
    height: 90px;
    background: radial-gradient(circle at 30% 30%, var(--yellow) 0%, var(--orange) 45%, var(--red) 100%);
    top: 50%;
    left: 20%;
    animation: float-complex 14s ease-in-out infinite, color-drift-circle 10s linear infinite;
    opacity: 0.08;
  }

  .contact-squiggle {
    position: absolute;
    bottom: 100px;
    right: 10%;
    transform: rotate(-10deg);
    width: 120px;
    animation: squiggle-drift 7s ease-in-out infinite alternate, color-drift-squiggle 8s linear infinite;
  }

  .contact-dots {
    position: absolute;
    width: 160px;
    height: 160px;
    top: 15%;
    left: 55%;
    background-image: radial-gradient(circle, var(--blue) 2px, transparent 2px);
    background-size: 18px 18px;
    opacity: 0.05;
    animation: float 12s ease-in-out infinite;
  }

  .contact-zigzag {
    position: absolute;
    width: 160px;
    height: 70px;
    top: 60%;
    right: 5%;
    animation: pulse-rotate 18s ease-in-out infinite;
  }

  .contact-blob {
    position: absolute;
    width: 260px;
    height: 260px;
    background: linear-gradient(135deg, var(--pink), var(--yellow));
    opacity: 0.08;
    bottom: 5%;
    right: 30%;
    animation: morph-blob 15s ease-in-out infinite, float-complex 22s ease-in-out infinite, color-drift-blob 10s linear infinite;
    filter: blur(1.5px);
    transition: scale 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                filter 0.3s ease, 
                opacity 0.3s ease;
  }

  .contact-blob:hover,
  .contact-blob.decor-active {
    animation-play-state: paused;
    scale: 1.15;
    opacity: 0.25 !important;
    filter: blur(1.5px) saturate(1.6) contrast(1.1);
  }

  @keyframes morph-blob {
    0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
    25% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
    50% { border-radius: 50% 60% 30% 60% / 40% 50% 50% 50%; }
    75% { border-radius: 60% 30% 50% 50% / 30% 60% 40% 70%; }
  }

  @keyframes color-drift {
    0% { filter: hue-rotate(0deg) saturate(1); }
    25% { filter: hue-rotate(90deg) saturate(1.2); }
    50% { filter: hue-rotate(180deg) saturate(1); }
    75% { filter: hue-rotate(270deg) saturate(1.1); }
    100% { filter: hue-rotate(360deg) saturate(1); }
  }

  @keyframes float-complex {
    0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
    25% { transform: translate(40px, -50px) rotate(5deg) scale(1.08); }
    50% { transform: translate(-20px, -90px) rotate(-3deg) scale(0.95); }
    75% { transform: translate(-50px, -30px) rotate(4deg) scale(1.03); }
  }

  @keyframes blob-float-rotate {
    0% { transform: translate(0, 0) rotate(0deg) scale(1); }
    25% { transform: translate(30px, -40px) rotate(90deg) scale(1.05); }
    50% { transform: translate(-15px, -70px) rotate(180deg) scale(0.95); }
    75% { transform: translate(-40px, -20px) rotate(270deg) scale(1.02); }
    100% { transform: translate(0, 0) rotate(360deg) scale(1); }
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--red);
    display: block;
    margin-bottom: 8px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 12px;
    position: relative;
    display: inline-block;
  }

  .section-title::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: 0;
    width: 100%;
    height: 8px;
    background: var(--pink);
    opacity: 0.3;
    z-index: -1;
  }

  .section-desc {
    font-size: 1rem;
    color: var(--black);
    opacity: 0.6;
    max-width: 440px;
  }

  .contact-layout {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 48px;
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }

  .contact-info {
    flex: 1;
    min-width: 280px;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 280px;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    text-decoration: none;
    color: var(--black);
    border: 2px solid transparent;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                background 0.3s ease,
                color 0.3s ease,
                box-shadow 0.3s ease;
    position: relative;
  }

  .contact-link:hover {
    border-color: var(--black);
    transform: translate(-4px, -4px);
    box-shadow: 6px 6px 0 var(--yellow);
    background: var(--white);
  }

  .contact-link-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--black);
    opacity: 0.8;
  }

  .contact-link-name {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex: 1;
  }

  .contact-link-arrow {
    font-size: 1.2rem;
    opacity: 0;
    transform: translateX(-10px);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.3s ease;
  }

  .contact-link:hover .contact-link-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @keyframes color-drift-circle {
    0% { filter: blur(3px) hue-rotate(0deg) saturate(1); }
    25% { filter: blur(3px) hue-rotate(90deg) saturate(1.2); }
    50% { filter: blur(3px) hue-rotate(180deg) saturate(1); }
    75% { filter: blur(3px) hue-rotate(270deg) saturate(1.1); }
    100% { filter: blur(3px) hue-rotate(360deg) saturate(1); }
  }

  @keyframes color-drift-blob {
    0% { filter: blur(1.5px) hue-rotate(0deg) saturate(1); }
    25% { filter: blur(1.5px) hue-rotate(90deg) saturate(1.2); }
    50% { filter: blur(1.5px) hue-rotate(180deg) saturate(1); }
    75% { filter: blur(1.5px) hue-rotate(270deg) saturate(1.1); }
    100% { filter: blur(1.5px) hue-rotate(360deg) saturate(1); }
  }

  @keyframes color-drift-squiggle {
    0% { filter: blur(1.5px) hue-rotate(0deg) saturate(1); }
    25% { filter: blur(1.5px) hue-rotate(90deg) saturate(1.2); }
    50% { filter: blur(1.5px) hue-rotate(180deg) saturate(1); }
    75% { filter: blur(1.5px) hue-rotate(270deg) saturate(1.1); }
    100% { filter: blur(1.5px) hue-rotate(360deg) saturate(1); }
  }
</style>
