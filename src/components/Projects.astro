---
import ProjectCard from "./ProjectCard.astro";
import projects from "../data/projects.json";
---

<section class="projects" id="projects">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-label">/ Projects</span>
      <h2 class="section-title">Мои работы</h2>
      <p class="section-desc">
        Проекты, которые мы сделали в студии Bazeform и не только
      </p>
    </div>
  </div>

  <div class="carousel-wrapper fade-in fade-in-delay-1">
    <div class="carousel" id="projects-carousel">
      {(projects.concat(projects)).map((project, i) => (
        <ProjectCard
          title={project.title}
          description={project.description}
          tags={project.tags}
          url={project.url}
          index={i % projects.length}
        />
      ))}
    </div>

    <!-- Carousel controls -->
    <div class="carousel-controls">
      <button class="carousel-btn carousel-btn--prev" id="carousel-prev" aria-label="Предыдущий">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M14 17L7 10L14 3" stroke="currentColor" stroke-width="3" stroke-linecap="square" stroke-linejoin="miter"/>
        </svg>
      </button>
      <button class="carousel-btn carousel-btn--next" id="carousel-next" aria-label="Следующий">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M6 3L13 10L6 17" stroke="currentColor" stroke-width="3" stroke-linecap="square" stroke-linejoin="miter"/>
        </svg>
      </button>
    </div>
  </div>
  <!-- Decorative animated elements -->
  <div class="projects-decor" aria-hidden="true">
    <div class="projects-circle projects-circle--green"></div>
    <div class="projects-circle projects-circle--pink"></div>
    <div class="projects-circle projects-circle--orange"></div>

    <svg class="projects-squiggle" viewBox="0 0 300 50">
      <path
        d="M0 25 Q30 0 60 25 T120 25 T180 25 T240 25 T300 25"
        fill="none"
        stroke="var(--black)"
        stroke-width="3"
        opacity="0.1"
      />
    </svg>

    <div class="projects-dots"></div>

    <svg class="projects-zigzag" viewBox="0 0 160 80">
      <polyline
        points="0,80 20,0 40,80 60,0 80,80 100,0 120,80 140,0 160,80"
        fill="none"
        stroke="var(--orange)"
        stroke-width="3"
        opacity="0.12"
      />
    </svg>

    <div class="projects-blob" aria-hidden="true"></div>
  </div>

  <!-- Decorative band -->
  <div class="projects-band" aria-hidden="true"></div>
</section>

<script>
  const carousel = document.getElementById("projects-carousel");
  const prevBtn = document.getElementById("carousel-prev");
  const nextBtn = document.getElementById("carousel-next");

  if (!carousel || !prevBtn || !nextBtn) throw new Error("Carousel elements not found");

  const cards = carousel.querySelectorAll(".project-card");
  const total = cards.length / 2;

  let isDown = false;
  let startX = 0;
  let scrollStart = 0;

  function getCardWidth() {
    return cards[0].getBoundingClientRect().width + 24;
  }

  function jumpTo(pos) {
    carousel.style.scrollBehavior = "auto";
    carousel.scrollLeft = pos;
    carousel.style.scrollBehavior = "";
  }

  function scroll(dir) {
    const step = getCardWidth();
    const maxScroll = step * total;

    if (dir > 0 && carousel.scrollLeft >= maxScroll - step) {
      jumpTo(0);
      carousel.scrollBy({ left: step, behavior: "smooth" });
    } else if (dir < 0 && carousel.scrollLeft < step) {
      jumpTo(maxScroll);
      carousel.scrollBy({ left: -step, behavior: "smooth" });
    } else {
      carousel.scrollBy({ left: dir * step, behavior: "smooth" });
    }
  }

  /* ── Drag-to-scroll via Pointer Events ── */
  carousel.addEventListener("pointerdown", (e) => {
    isDown = true;
    startX = e.pageX;
    scrollStart = carousel.scrollLeft;
    carousel.style.cursor = "grabbing";
    carousel.style.scrollSnapType = "none";
  });

  document.addEventListener("pointermove", (e) => {
    if (!isDown) return;
    const dx = e.pageX - startX;
    const cardWidth = getCardWidth();
    const maxScroll = cardWidth * total;

    let newPos = scrollStart - dx;

    if (newPos >= maxScroll) {
      scrollStart -= maxScroll;
      newPos -= maxScroll;
    } else if (newPos < 0) {
      scrollStart += maxScroll;
      newPos += maxScroll;
    }

    carousel.scrollLeft = newPos;
  });

  document.addEventListener("pointerup", () => {
    if (!isDown) return;
    isDown = false;
    carousel.style.cursor = "grab";
    carousel.style.scrollBehavior = "smooth";
    carousel.style.scrollSnapType = "";
    setTimeout(() => {
      carousel.style.scrollBehavior = "";
    }, 350);
  });

  document.addEventListener("pointercancel", () => {
    if (!isDown) return;
    isDown = false;
    carousel.style.cursor = "grab";
    carousel.style.scrollBehavior = "smooth";
    carousel.style.scrollSnapType = "";
    setTimeout(() => {
      carousel.style.scrollBehavior = "";
    }, 350);
  });



  /* ── Buttons ── */
  prevBtn.addEventListener("click", () => scroll(-1));
  nextBtn.addEventListener("click", () => scroll(1));

  /* ── Keyboard ── */
  carousel.addEventListener("keydown", (e) => {
    if (e.key === "ArrowLeft") scroll(-1);
    if (e.key === "ArrowRight") scroll(1);
  });

  /* ── Touch / wheel fine-tune ── */
  carousel.addEventListener("wheel", (e) => {
    if (Math.abs(e.deltaX) < Math.abs(e.deltaY)) return;
    e.preventDefault();
  }, { passive: false });
</script>


<style>
  .projects {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 0;
    position: relative;
    background: var(--white);
  }

  .section-header {
    margin-bottom: 40px;
    position: relative;
  }



  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--red);
    display: block;
    margin-bottom: 8px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 12px;
    position: relative;
    display: inline-block;
  }

  .section-title::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: 0;
    width: 100%;
    height: 8px;
    background: var(--yellow);
    opacity: 0.3;
    z-index: -1;
  }

  .section-desc {
    font-size: 1rem;
    color: var(--black);
    opacity: 0.6;
    max-width: 480px;
  }

  .carousel-wrapper {
    position: relative;
    padding: 0 24px;
  }

  .carousel {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-x pinch-zoom;
    padding: 16px 4px 24px;
    scrollbar-width: none;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }


  .carousel::-webkit-scrollbar {
    display: none;
  }



  .carousel-controls {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 24px;
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 24px;
  }

  .carousel-btn {
    width: 52px;
    height: 52px;
    border: 3px solid var(--black);
    background: var(--white);
    color: var(--black);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                background 0.3s ease,
                color 0.3s ease,
                box-shadow 0.3s ease;
  }

  .carousel-btn:hover {
    background: var(--black);
    color: var(--white);
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--red);
  }

  .carousel-btn:active {
    transform: translate(0, 0);
    box-shadow: none;
  }

  .projects-band {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 8px;
    background: repeating-linear-gradient(
      90deg,
      var(--black) 0px,
      var(--black) 15px,
      var(--yellow) 15px,
      var(--yellow) 30px,
      var(--pink) 30px,
      var(--pink) 45px,
      var(--blue) 45px,
      var(--blue) 60px,
      var(--green) 60px,
      var(--green) 75px
    );
    background-size: 75px 8px;
    animation: hue-shift 3s steps(6) infinite;
  }
  /* ── Animated decorative elements ── */

  .projects-decor {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  /* ── Interactive Shapes Hover ── */
  .projects-circle,
  .projects-squiggle,
  .projects-zigzag,
  .projects-blob,
  .projects-dots {
    cursor: pointer;
    pointer-events: auto;
    transition: scale 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                filter 0.3s ease, 
                opacity 0.3s ease;
  }

  .projects-circle:hover,
  .projects-squiggle:hover,
  .projects-zigzag:hover,
  .projects-blob:hover {
    scale: 1.18;
    opacity: 0.45 !important;
    filter: drop-shadow(8px 8px 0 rgba(0, 0, 0, 0.1)) saturate(1.3);
  }

  .projects-dots:hover {
    scale: 1.08;
    opacity: 0.3 !important;
  }
  .projects-circle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.1;
  }

  .projects-circle--green {
    width: 220px;
    height: 220px;
    background: var(--green);
    bottom: -60px;
    left: -80px;
    animation: float-complex 18s ease-in-out infinite, color-drift 14s linear infinite;
  }

  .projects-circle--pink {
    width: 160px;
    height: 160px;
    background: var(--pink);
    top: -40px;
    right: -50px;
    animation: float-complex 22s ease-in-out infinite reverse, color-drift 16s linear infinite reverse;
    opacity: 0.08;
  }

  .projects-circle--orange {
    width: 80px;
    height: 80px;
    background: var(--orange);
    top: 40%;
    left: 10%;
    animation: float-complex 12s ease-in-out infinite, color-drift 10s linear infinite;
    opacity: 0.08;
  }

  .projects-squiggle {
    position: absolute;
    width: 160px;
    height: 50px;
    top: 18%;
    right: 5%;
    animation: squiggle-drift 10s ease-in-out infinite alternate, color-drift 8s linear infinite;
  }

  .projects-dots {
    position: absolute;
    width: 180px;
    height: 180px;
    top: 55%;
    left: 60%;
    background-image: radial-gradient(circle, var(--black) 2px, transparent 2px);
    background-size: 20px 20px;
    opacity: 0.05;
    animation: float 14s ease-in-out infinite;
  }

  .projects-zigzag {
    position: absolute;
    width: 140px;
    height: 80px;
    bottom: 25%;
    right: 12%;
    animation: pulse-rotate 15s ease-in-out infinite;
  }

  .projects-blob {
    position: absolute;
    width: 200px;
    height: 200px;
    background: linear-gradient(135deg, var(--purple), var(--blue));
    opacity: 0.06;
    top: 50%;
    left: -5%;
    animation: morph-blob 16s ease-in-out infinite, float-complex 20s ease-in-out infinite, color-drift 12s linear infinite;
    filter: blur(40px);
  }

  @keyframes morph-blob {
    0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
    25% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
    50% { border-radius: 50% 60% 30% 60% / 40% 50% 50% 50%; }
    75% { border-radius: 60% 30% 50% 50% / 30% 60% 40% 70%; }
  }

  @keyframes color-drift {
    0% { filter: hue-rotate(0deg) saturate(1); }
    25% { filter: hue-rotate(90deg) saturate(1.2); }
    50% { filter: hue-rotate(180deg) saturate(1); }
    75% { filter: hue-rotate(270deg) saturate(1.1); }
    100% { filter: hue-rotate(360deg) saturate(1); }
  }

  @keyframes float-complex {
    0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
    25% { transform: translate(40px, -50px) rotate(5deg) scale(1.08); }
    50% { transform: translate(-20px, -90px) rotate(-3deg) scale(0.95); }
    75% { transform: translate(-50px, -30px) rotate(4deg) scale(1.03); }
  }
</style>
