---
import ProjectCard from "./ProjectCard.astro";
import projects from "../data/projects.json";
---

<section class="projects" id="projects">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-label">/ Projects</span>
      <h2 class="section-title">Выбранные работы</h2>
      <p class="section-desc">
        Проекты, которые мы сделали в студии Bazeform и не только
      </p>
    </div>
  </div>

  <div class="carousel-wrapper fade-in fade-in-delay-1">
    <div class="carousel" id="projects-carousel">
      {(projects.concat(projects)).map((project, i) => (
        <ProjectCard
          title={project.title}
          description={project.description}
          tags={project.tags}
          url={project.url}
          index={i % projects.length}
        />
      ))}
    </div>

    <!-- Carousel controls -->
    <div class="carousel-controls">
      <button class="carousel-btn carousel-btn--prev" id="carousel-prev" aria-label="Предыдущий">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M14 17L7 10L14 3" stroke="currentColor" stroke-width="3" stroke-linecap="square" stroke-linejoin="miter"/>
        </svg>
      </button>
      <button class="carousel-btn carousel-btn--next" id="carousel-next" aria-label="Следующий">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M6 3L13 10L6 17" stroke="currentColor" stroke-width="3" stroke-linecap="square" stroke-linejoin="miter"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Decorative band -->
  <div class="projects-band" aria-hidden="true"></div>
</section>

<script>
  const carousel = document.getElementById("projects-carousel");
  const prevBtn = document.getElementById("carousel-prev");
  const nextBtn = document.getElementById("carousel-next");

  if (carousel && prevBtn && nextBtn) {
    const cards = carousel.querySelectorAll(".project-card");
    const total = cards.length / 2;

    const getCardWidth = () => {
      return cards[0].getBoundingClientRect().width + 24;
    };

    const jumpTo = (pos) => {
      carousel.style.scrollBehavior = "auto";
      carousel.scrollLeft = pos;
      carousel.style.scrollBehavior = "";
    };

    const scroll = (dir) => {
      const step = getCardWidth();
      const maxScroll = step * total;

      if (dir > 0 && carousel.scrollLeft >= maxScroll - step) {
        jumpTo(0);
        carousel.scrollBy({ left: step, behavior: "smooth" });
      } else if (dir < 0 && carousel.scrollLeft < step) {
        jumpTo(maxScroll);
        carousel.scrollBy({ left: -step, behavior: "smooth" });
      } else {
        carousel.scrollBy({ left: dir * step, behavior: "smooth" });
      }
    };

    prevBtn.addEventListener("click", () => scroll(-1));
    nextBtn.addEventListener("click", () => scroll(1));

    carousel.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft") scroll(-1);
      if (e.key === "ArrowRight") scroll(1);
    });
  }
</script>

<style>
  .projects {
    padding: 100px 0;
    position: relative;
    background: var(--white);
  }

  .section-header {
    margin-bottom: 48px;
    position: relative;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--red);
    display: block;
    margin-bottom: 8px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 12px;
    position: relative;
    display: inline-block;
  }

  .section-title::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: 0;
    width: 100%;
    height: 8px;
    background: var(--yellow);
    opacity: 0.3;
    z-index: -1;
  }

  .section-desc {
    font-size: 1rem;
    color: var(--black);
    opacity: 0.6;
    max-width: 480px;
  }

  .carousel-wrapper {
    position: relative;
    padding: 0 24px;
  }

  .carousel {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 16px 4px 24px;
    scrollbar-width: none;
    cursor: grab;
  }

  .carousel::-webkit-scrollbar {
    display: none;
  }

  .carousel:active {
    cursor: grabbing;
  }

  .carousel-controls {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 24px;
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 24px;
  }

  .carousel-btn {
    width: 52px;
    height: 52px;
    border: 3px solid var(--black);
    background: var(--white);
    color: var(--black);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .carousel-btn:hover {
    background: var(--black);
    color: var(--white);
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--red);
  }

  .carousel-btn:active {
    transform: translate(0, 0);
    box-shadow: none;
  }

  .projects-band {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 8px;
    background: repeating-linear-gradient(
      90deg,
      var(--black) 0px,
      var(--black) 15px,
      var(--yellow) 15px,
      var(--yellow) 30px,
      var(--pink) 30px,
      var(--pink) 45px,
      var(--blue) 45px,
      var(--blue) 60px,
      var(--green) 60px,
      var(--green) 75px
    );
    background-size: 75px 8px;
    animation: hue-shift 3s steps(6) infinite;
  }
</style>
