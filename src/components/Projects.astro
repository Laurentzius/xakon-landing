---
import projects from "../data/projects.json";
---

<section class="projects" id="projects">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-label">/ Projects</span>
      <h2 class="section-title">Мои работы</h2>
      <p class="section-desc">
        Проекты, которые мы сделали в студии Bazeform и не только
      </p>
    </div>
  </div>

  <div class="accordion-wrapper fade-in fade-in-delay-1">
    <div class="projects-accordion has-active" id="projects-accordion">
      {projects.map((project, i) => {
        const accentColors = ["var(--red)", "var(--blue)", "var(--yellow)", "var(--green)", "var(--pink)", "var(--orange)"];
        const accentColor = accentColors[i % accentColors.length];
        return (
          <div class="project-column" style={`--accent: ${accentColor}`} data-index={i}>
            <!-- Dimmed Background Image Layer -->
            <div class="column-bg" style={`background-image: url(${project.image})`}></div>

            <!-- Collapsed Content -->
            <div class="column-collapsed-content">
              <span class="collapsed-num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="collapsed-title">{project.title}</h3>
            </div>

            <!-- Expanded Content -->
            <div class="column-content">
              <div class="column-info">
                <span class="column-num">/ {String(i + 1).padStart(2, '0')}</span>
                <h3 class="column-title">{project.title}</h3>
                <p class="column-desc">{project.description}</p>
                <div class="column-tags">
                  {project.tags.map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
              <div class="column-image-wrapper">
                <div class="column-image-box">
                  <div class="column-image" style={`background-image: url(${project.image})`}></div>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Decorative animated elements -->
  <div class="projects-decor" aria-hidden="true">
    <div class="projects-circle projects-circle--green" data-decor></div>
    <div class="projects-circle projects-circle--pink" data-decor></div>
    <div class="projects-circle projects-circle--orange" data-decor></div>

    <svg class="projects-squiggle" data-decor viewBox="0 0 300 50">
      <defs>
        <linearGradient id="projects-squiggle-grad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="var(--pink)" />
          <stop offset="50%" stop-color="var(--purple)" />
          <stop offset="100%" stop-color="var(--blue)" />
        </linearGradient>
      </defs>
      <path
        d="M0 25 Q30 0 60 25 T120 25 T180 25 T240 25 T300 25"
        fill="none"
        stroke="url(#projects-squiggle-grad)"
        stroke-width="4"
        opacity="0.2"
      />
    </svg>

    <div class="projects-dots" data-decor></div>

    <svg class="projects-zigzag" data-decor viewBox="0 0 160 80">
      <defs>
        <linearGradient id="projects-zigzag-grad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="var(--orange)" />
          <stop offset="50%" stop-color="var(--yellow)" />
          <stop offset="100%" stop-color="var(--red)" />
        </linearGradient>
      </defs>
      <polyline
        points="0,80 20,0 40,80 60,0 80,80 100,0 120,80 140,0 160,80"
        fill="none"
        stroke="url(#projects-zigzag-grad)"
        stroke-width="4"
        opacity="0.22"
      />
    </svg>
    <div class="projects-blob" data-decor aria-hidden="true"></div>
  </div>

  <!-- Decorative band -->
  <div class="projects-band" aria-hidden="true"></div>
</section>

<script>
  const accordion = document.getElementById("projects-accordion");
  const columns = document.querySelectorAll(".project-column");

  if (accordion && columns.length > 0) {
    // Set first item active by default
    columns[0].classList.add("is-active");

    columns.forEach((column) => {
      column.addEventListener("click", (e) => {
        e.stopPropagation(); // prevent document click listener from closing
        
        const isActive = column.classList.contains("is-active");

        // Clear active state on all columns
        columns.forEach((c) => {
          c.classList.remove("is-active");
        });

        if (!isActive) {
          column.classList.add("is-active");
          accordion.classList.add("has-active");
        } else {
          // If clicked the already active one, collapse it!
          accordion.classList.remove("has-active");
        }
      });
    });

    // Collapse when clicking anywhere else on the page
    document.addEventListener("click", (e) => {
      const isColumn = e.target.closest(".project-column");
      if (!isColumn) {
        columns.forEach((c) => {
          c.classList.remove("is-active");
        });
        accordion.classList.remove("has-active");
      }
    });
  }
</script>

<style>
  .projects {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 0;
    position: relative;
    background: var(--white);
    overflow: hidden;
  }

  .section-header {
    margin-bottom: 40px;
    position: relative;
    z-index: 1;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--red);
    display: block;
    margin-bottom: 8px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 12px;
    position: relative;
    display: inline-block;
  }

  .section-title::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: 0;
    width: 100%;
    height: 8px;
    background: var(--yellow);
    opacity: 0.3;
    z-index: -1;
  }

  .section-desc {
    font-size: 1rem;
    color: var(--black);
    opacity: 0.6;
    max-width: 480px;
  }

  /* ── Accordion ── */

  .accordion-wrapper {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  .projects-accordion {
    display: flex;
    gap: 16px;
    width: 100%;
    height: 520px;
    box-sizing: border-box;
  }

  .project-column {
    flex: 1;
    min-width: 80px;
    height: 100%;
    border: 3px solid var(--black);
    background: var(--white);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    box-sizing: border-box;
    transition: flex 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.3s ease,
                border-color 0.3s ease,
                background-color 0.3s ease;
  }
  
  [data-theme="light"] .project-column {
    border-color: var(--white);
  }

  /* Dimmed Background Image Layer */
  .column-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
    transition: filter 0.4s ease, opacity 0.4s ease, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    filter: grayscale(0.15) brightness(0.4);
    opacity: 0.95;
  }

  /* Subtle dark gradient overlay to guarantee text readability in collapsed state */
  .column-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.1), rgba(0, 0, 0, 0.7));
    transition: opacity 0.4s ease;
    opacity: 0.6;
  }

  /* Collapsed Hover: Light up the image, but do NOT expand yet */
  .project-column:not(.is-active):hover {
    transform: translate(-3px, -3px);
    box-shadow: 6px 6px 0 var(--accent);
    border-color: var(--accent);
  }

  .project-column:not(.is-active):hover .column-bg {
    filter: grayscale(0) brightness(0.8);
    transform: scale(1.03);
  }

  .project-column:not(.is-active):hover .column-bg::after {
    opacity: 0.35;
  }

  /* Accordion active logic (controlled via JS class) */
  .projects-accordion.has-active .project-column {
    flex: 0.65;
  }

  .projects-accordion.has-active .project-column.is-active {
    flex: 4.5;
    transform: translate(-6px, -6px);
    box-shadow: 10px 10px 0 var(--accent);
    border-color: var(--accent);
    background: var(--white);
    cursor: default;
  }

  /* When active, fade out the background image layer to let the white readable background work */
  .project-column.is-active .column-bg {
    opacity: 0;
    pointer-events: none;
  }

  /* Fade out collapsed components on active */
  .project-column.is-active .column-collapsed-content {
    opacity: 0;
    pointer-events: none;
  }

  /* Fade in expanded components on active */
  .project-column.is-active .column-content {
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.2s ease 0.25s;
  }

  .project-column.is-active .column-image {
    transform: scale(1.05);
  }

  /* ── Collapsed Content ── */

  .column-collapsed-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 32px 12px;
    box-sizing: border-box;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.3s ease;
    z-index: 2;
  }

  .collapsed-num {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.1rem;
    color: #ffffff;
    opacity: 0.85;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.4);
  }

  .collapsed-title {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: #ffffff !important;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
    text-transform: uppercase;
    white-space: nowrap;
    letter-spacing: -0.01em;
    margin: auto 0;
  }


  /* ── Expanded Content ── */

  .column-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 32px;
    padding: 40px;
    min-width: 520px;
    box-sizing: border-box;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;
    z-index: 1;
  }

  .column-info {
    flex: 1.2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
  }

  .column-num {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 8px;
    display: block;
  }

  .column-title {
    font-family: var(--font-display);
    font-size: 2.25rem;
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
    position: relative;
    width: fit-content;
  }

  .column-title::after {
    content: "";
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 100%;
    height: 4px;
    background: var(--accent);
    opacity: 0.3;
  }

  .column-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--black);
    opacity: 0.8;
    margin-bottom: 24px;
  }

  .column-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 2px solid var(--black);
    background: transparent;
    color: var(--black);
    transition: all 0.2s;
  }

  .project-column.is-active .tag {
    border-color: var(--accent);
    color: var(--accent);
  }

  .column-image-wrapper {
    flex: 1;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .column-image-box {
    width: 100%;
    height: 300px;
    border: 3px solid var(--black);
    box-shadow: 6px 6px 0 var(--black);
    overflow: hidden;
    position: relative;
    background: var(--black);
  }

  .column-image {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ── Mobile Layout ── */

  @media (max-width: 992px) {
    .projects {
      min-height: auto !important;
      padding: 60px 0 50px;
    }

    .projects-accordion {
      flex-direction: column;
      height: auto !important; /* Dynamic height */
      gap: 16px;
    }

    .project-column {
      width: 100%;
      height: auto !important;
      max-height: 70px !important; /* Set standard height in collapsed state */
      min-height: 70px !important; /* Force standard collapsed height so it never shrinks to 0px lines */
      flex: none !important; /* Disable flex scale */
      overflow: hidden;
      transition: max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), 
                  box-shadow 0.3s ease, 
                  border-color 0.3s ease;
    }

    /* Inactive columns: standard height */
    .project-column:not(.is-active) {
      max-height: 70px !important;
    }

    .projects-accordion.has-active .project-column {
      flex: none !important;
    }

    .projects-accordion.has-active .project-column.is-active {
      flex: none !important;
      max-height: 550px !important; /* Transition smoothly to expanded size */
      transform: translate(-4px, -4px);
      box-shadow: 8px 8px 0 var(--accent);
    }

    /* Collapsed mobile */
    .column-collapsed-content {
      position: absolute !important;
      inset: 0 !important;
      flex-direction: row !important;
      padding: 0 20px !important;
      align-items: center !important;
      justify-content: space-between !important;
      opacity: 1 !important;
      transition: opacity 0.3s ease !important;
      pointer-events: auto !important;
      display: flex !important;
    }

    .collapsed-title {
      writing-mode: horizontal-tb !important;
      transform: none !important;
      margin: 0 !important;
      font-size: 1.15rem !important;
    }

    .collapsed-num {
      font-size: 1rem !important;
    }

    .project-column.is-active .column-collapsed-content {
      opacity: 0 !important;
      pointer-events: none !important;
    }

    /* Expanded mobile */
    .column-content {
      position: relative !important; /* Render in flow so parent height expands naturally */
      opacity: 0 !important;
      pointer-events: none !important;
      display: flex !important;
      transition: opacity 0.3s ease !important;
      padding: 24px !important;
      width: 100% !important;
      min-width: 100% !important;
      gap: 20px !important;
      flex-direction: column !important;
    }

    .project-column.is-active .column-content {
      display: flex !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      transition: opacity 0.4s ease 0.15s !important; /* Smooth delay on expand */
    }

    .column-info {
      flex: none !important;
      height: auto !important;
    }

    .column-title {
      font-size: 1.6rem !important;
      margin-bottom: 8px !important;
    }

    .column-desc {
      font-size: 0.85rem !important;
      margin-bottom: 16px !important;
      line-height: 1.5 !important;
    }

    .column-image-wrapper {
      flex: none !important;
      width: 100% !important;
      height: auto !important;
    }

    .column-image-box {
      height: 180px !important; /* Set standard height on mobile */
    }
  }

  @media (max-width: 768px) {
    .projects-decor {
      display: block !important;
      opacity: 1 !important;
    }

    .projects-decor * {
      pointer-events: none !important; /* Lock clicks and touch states */
    }

    .projects-circle--green {
      width: 120px !important;
      height: 120px !important;
      bottom: -30px !important;
      left: -40px !important;
      opacity: 0.35 !important;
    }

    .projects-circle--pink {
      width: 100px !important;
      height: 100px !important;
      top: -20px !important;
      right: -30px !important;
      opacity: 0.35 !important;
    }

    .projects-circle--orange {
      width: 50px !important;
      height: 50px !important;
      top: 30% !important;
      left: 3% !important;
      opacity: 0.35 !important;
    }

    .projects-squiggle {
      width: 90px !important;
      height: 30px !important;
      top: 15% !important;
      right: 3% !important;
      opacity: 0.40 !important;
    }

    .projects-dots {
      width: 110px !important;
      height: 110px !important;
      top: 60% !important;
      left: 70% !important;
      opacity: 0.18 !important;
    }

    .projects-zigzag {
      width: 80px !important;
      height: 45px !important;
      bottom: 20% !important;
      right: 4% !important;
      opacity: 0.40 !important;
    }

    .projects-blob {
      width: 150px !important;
      height: 150px !important;
      bottom: 8% !important;
      left: 15% !important;
      opacity: 0.18 !important;
    }
  }
  /* ── Decorative elements ── */

  .projects-band {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 8px;
    background: repeating-linear-gradient(
      90deg,
      var(--black) 0px,
      var(--black) 15px,
      var(--yellow) 15px,
      var(--yellow) 30px,
      var(--pink) 30px,
      var(--pink) 45px,
      var(--blue) 45px,
      var(--blue) 60px,
      var(--green) 60px,
      var(--green) 75px
    );
    background-size: 75px 8px;
    animation: hue-shift 3s steps(6) infinite;
  }

  /* ── Animated decorative elements ── */

  .projects-decor {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  /* ── Interactive Shapes Hover ── */
  .projects-circle,
  .projects-squiggle,
  .projects-zigzag,
  .projects-blob,
  .projects-dots {
    cursor: pointer;
    pointer-events: auto;
    transition: scale 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                filter 0.3s ease, 
                opacity 0.3s ease;
  }

  .projects-squiggle,
  .projects-zigzag {
  }

  .projects-squiggle:hover,
  .projects-squiggle.decor-active {
    scale: 1.18;
    opacity: 0.45 !important;
  }

  .projects-zigzag:hover,
  .projects-zigzag.decor-active {
    scale: 1.18;
    opacity: 0.45 !important;
    filter: saturate(1.5);
  }

  .projects-dots {
  }

  .projects-dots:hover,
  .projects-dots.decor-active {
    scale: 1.08;
    opacity: 0.3 !important;
    filter: saturate(1.5);
  }

  .projects-circle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.1;
    transition: scale 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                filter 0.3s ease, 
                opacity 0.3s ease;
  }

  .projects-circle:hover,
  .projects-circle.decor-active {
    scale: 1.18;
    opacity: 0.45 !important;
  }
  .projects-circle--green {
    width: 220px;
    height: 220px;
    background: radial-gradient(circle at 30% 30%, var(--green) 0%, var(--blue) 45%, var(--purple) 100%);
    bottom: -60px;
    left: -80px;
    animation: float-complex 18s ease-in-out infinite, color-drift-glow 10s linear infinite;
  }

  .projects-circle--pink {
    width: 160px;
    height: 160px;
    background: radial-gradient(circle at 30% 30%, var(--pink) 0%, var(--purple) 45%, var(--blue) 100%);
    top: -40px;
    right: -50px;
    animation: float-complex 22s ease-in-out infinite reverse, color-drift-glow 10s linear infinite reverse;
    opacity: 0.08;
  }

  .projects-circle--orange {
    width: 80px;
    height: 80px;
    background: radial-gradient(circle at 30% 30%, var(--orange) 0%, var(--red) 45%, var(--purple) 100%);
    top: 40%;
    left: 10%;
    animation: float-complex 12s ease-in-out infinite, color-drift-glow 10s linear infinite;
    opacity: 0.08;
  }

  .projects-squiggle {
    position: absolute;
    width: 160px;
    height: 50px;
    top: 18%;
    right: 5%;
    animation: squiggle-drift 10s ease-in-out infinite alternate, color-drift-glow 8s linear infinite;
  }

  .projects-dots {
    position: absolute;
    width: 180px;
    height: 180px;
    top: 55%;
    left: 60%;
    background-image: radial-gradient(circle, var(--pink) 2px, transparent 2px);
    background-size: 20px 20px;
    opacity: 0.05;
    animation: float 14s ease-in-out infinite;
  }

  .projects-zigzag {
    position: absolute;
    width: 140px;
    height: 80px;
    bottom: 25%;
    right: 12%;
    animation: pulse-rotate 15s ease-in-out infinite;
  }

  .projects-blob {
    position: absolute;
    width: 280px;
    height: 280px;
    background: linear-gradient(135deg, var(--purple), var(--pink));
    opacity: 0.08;
    top: 50%;
    left: -5%;
    animation: morph-blob 16s ease-in-out infinite, float-complex 20s ease-in-out infinite, color-drift-glow 10s linear infinite;
    transition: scale 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                filter 0.3s ease, 
                opacity 0.3s ease;
  }

  .projects-blob:hover,
  .projects-blob.decor-active {
    scale: 1.15;
    opacity: 0.25 !important;
  }

  @keyframes morph-blob {
    0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
    25% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
    50% { border-radius: 50% 60% 30% 60% / 40% 50% 50% 50%; }
    75% { border-radius: 60% 30% 50% 50% / 30% 60% 40% 70%; }
  }

  @keyframes color-drift {
    0% { filter: hue-rotate(0deg) saturate(1); }
    25% { filter: hue-rotate(90deg) saturate(1.2); }
    50% { filter: hue-rotate(180deg) saturate(1); }
    75% { filter: hue-rotate(270deg) saturate(1.1); }
    100% { filter: hue-rotate(360deg) saturate(1); }
  }
  @keyframes float-complex {
    0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
    25% { transform: translate(40px, -50px) rotate(5deg) scale(1.08); }
    50% { transform: translate(-20px, -90px) rotate(-3deg) scale(0.95); }
    75% { transform: translate(-50px, -30px) rotate(4deg) scale(1.03); }
  }

  @keyframes blob-float-rotate {
    0% { transform: translate(0, 0) rotate(0deg) scale(1); }
