---
// Hero with full Memphis retro treatment
const studioName = "XAKON.DEV";
const subtitle = "web developer / ai-first engineer";
---

<section class="hero">
  <div class="container">
    <!-- Decorative background elements -->
    <div class="hero-decor" id="hero-decor" aria-hidden="true">
      <div class="hero-circle hero-circle--red" data-decor></div>
      <div class="hero-circle hero-circle--blue" data-decor></div>
      <div class="hero-circle hero-circle--yellow" data-decor></div>

      <svg class="hero-squiggle" data-decor viewBox="0 0 300 50">
        <path
          d="M0 25 Q30 0 60 25 T120 25 T180 25 T240 25 T300 25"
          fill="none"
          stroke="var(--black)"
          stroke-width="3"
          opacity="0.1"
        />
      </svg>

      <div class="hero-grid" data-decor></div>

      <svg class="hero-zigzag" data-decor viewBox="0 0 200 80">
        <polyline
          points="0,80 25,0 50,80 75,0 100,80 125,0 150,80 175,0 200,80"
          fill="none"
          stroke="var(--red)"
          stroke-width="3"
          opacity="0.12"
        />
      </svg>

      <div class="hero-dots" data-decor></div>
      <div class="hero-blob" data-decor aria-hidden="true"></div>
    </div>

    <div class="hero-content">
      <div class="hero-badge hero-reveal" id="hero-badge"><span id="badge-text">thinking.</span></div>
      <h1 class="hero-title" id="theme-toggle-title">
        <span class="hero-title-line"><span class="typewriter-wrap" id="typewriter-wrap"><span id="typewriter-text"></span><span class="typewriter-cursor">|</span></span></span>
      </h1>
      <p class="hero-subtitle hero-reveal" id="hero-subtitle">{subtitle}</p>
      <div class="hero-actions hero-reveal" id="hero-actions">
        <a href="#projects" class="btn btn--primary">Проекты</a>
        <a href="#contact" class="btn btn--outline">Связаться</a>
      </div>
    </div>
  </div>

<script>
  const title = document.getElementById("theme-toggle-title");

  function getPreferredTheme() {
    const stored = localStorage.getItem("theme");
    if (stored) return stored;
    return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  }

  function setTheme(theme) {
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem("theme", theme);
  }

  const savedTheme = getPreferredTheme();
  setTheme(savedTheme);

  title.addEventListener("click", () => {
    const current = document.documentElement.getAttribute("data-theme");
    setTheme(current === "dark" ? "light" : "dark");
  });

  window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
    if (!localStorage.getItem("theme")) {
      setTheme(e.matches ? "dark" : "light");
    }
  });
  /* ── Badge word rotator ── */
  (function() {
    var el = document.getElementById("badge-text");
    if (!el) return;

    var words = ["thinking", "generating", "working", "loading", "compiling"];
    var wi = 0;
    var di = 0;
    var dotSeq = [".", "..", "..."];
    var tick = 0;
    var CYCLES = 20;

    function render() {
      el.textContent = words[wi] + dotSeq[di];
    }

    render();

    setInterval(function() {
      di = (di + 1) % dotSeq.length;
      tick++;
      if (tick >= CYCLES) {
        tick = 0;
        wi = (wi + 1) % words.length;
      }
      el.textContent = words[wi] + dotSeq[di];
    }, 400);
  })();
  /* ── Typewriter + staggered reveal ── */
  (function() {
    var el = document.getElementById("typewriter-text");
    var badge = document.getElementById("hero-badge");
    var sub = document.getElementById("hero-subtitle");
    var actions = document.getElementById("hero-actions");
    var decor = document.getElementById("hero-decor");
    if (!el) return;

    var text = "XAKON.DEV";
    var i = 0;
    var speed = 90;

    function type() {
      if (i < text.length) {
        el.textContent += text.charAt(i);
        i++;
        setTimeout(type, speed);
      } else {
        setTimeout(function() { if (badge) badge.classList.add("visible"); }, 150);
        setTimeout(function() { if (sub) sub.classList.add("visible"); }, 450);
        setTimeout(function() { if (actions) actions.classList.add("visible"); }, 750);
        setTimeout(function() { if (decor) decor.classList.add("revealed"); }, 1050);
      }
    }
    setTimeout(function() {
      var wrap = document.getElementById("typewriter-wrap");
      if (wrap) wrap.classList.add("visible");
      type();
    }, 400);
  })();
  /* ── Click decor shape → expand to fullscreen ── */
  (function() {
    var decor = document.getElementById("hero-decor");
    if (!decor) return;

    var SHAPES = '.hero-circle, .hero-squiggle, .hero-zigzag, .hero-blob, .hero-grid, .hero-dots';
    var savedRect = null;
    var isFull = false;

    decor.addEventListener('click', function(e) {
      var shape = e.target.closest(SHAPES);
      if (!shape) return;
      if (isFull) collapse(); else expand();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && isFull) collapse();
    });

    function expand() {
      var rect = decor.getBoundingClientRect();
      savedRect = rect;

      // Cancel any active animations + reset inline transition
      decor.getAnimations().forEach(function(a) { a.cancel(); });
      decor.style.transition = 'none';

      // Start visually in-place using absolute dimensions converted to fixed
      decor.style.position = 'fixed';
      decor.style.inset = 'auto'; // Disable CSS top/right/bottom/left conflicts
      decor.style.top = rect.top + 'px';
      decor.style.left = rect.left + 'px';
      decor.style.width = rect.width + 'px';
      decor.style.height = rect.height + 'px';
      decor.style.overflow = 'visible'; // Let shapes float beyond bounds during fullscreen
      decor.style.zIndex = '0'; // Keep behind text & buttons
      decor.style.margin = '0';
      decor.style.transform = 'none';
      decor.style.borderRadius = '24px';

      // Force reflow
      decor.offsetHeight;

      // Brighten all shapes to match hover state
      decor.querySelectorAll(SHAPES).forEach(function(s) {
        if (s.classList.contains('hero-grid') || s.classList.contains('hero-dots')) {
          s.style.scale = '1.08';
          s.style.opacity = '0.3';
        } else {
          s.style.scale = '1.18';
          s.style.opacity = '0.45';
          s.style.filter = 'drop-shadow(8px 8px 0 rgba(0, 0, 0, 0.1)) saturate(1.3)';
        }
      });

      // Playful springy transition on physical boundaries (no squashing of shapes)
      var spring = '0.8s cubic-bezier(0.175, 0.885, 0.32, 1.1)';
      decor.style.transition = 'top ' + spring + ', left ' + spring + ', width ' + spring + ', height ' + spring + ', border-radius ' + spring;
      
      decor.style.top = '0';
      decor.style.left = '0';
      decor.style.width = '100vw';
      decor.style.height = '100vh';
      decor.style.borderRadius = '0';


      isFull = true;
    }

    function collapse() {
      if (!savedRect) return;

      // Reset shape brightness so they fade back during the collapse animation
      decor.querySelectorAll(SHAPES).forEach(function(s) {
        s.style.scale = s.style.opacity = s.style.filter = '';
        s.classList.remove('decor-active');
      });

      // Set overflow: hidden IMMEDIATELY at the start of collapse so the shapes'
      // clipping mask transitions smoothly instead of snapping at the very end.
      decor.style.overflow = 'hidden';

      var smooth = '0.7s cubic-bezier(0.16, 1, 0.3, 1)';
      decor.style.transition = 'top ' + smooth + ', left ' + smooth + ', width ' + smooth + ', height ' + smooth + ', border-radius ' + smooth;
      
      decor.style.top = savedRect.top + 'px';
      decor.style.left = savedRect.left + 'px';
      decor.style.width = savedRect.width + 'px';
      decor.style.height = savedRect.height + 'px';
      decor.style.borderRadius = '24px';

      // Track all transitioning properties to ensure 100% complete rendering before cleanup
      var pendingProps = ['top', 'left', 'width', 'height', 'border-radius'];
      var cleanedUp = false;
      
      function onEnd(e) {
        if (cleanedUp) return;
        var idx = pendingProps.indexOf(e.propertyName);
        if (idx !== -1) pendingProps.splice(idx, 1);
        if (pendingProps.length > 0) return;
        cleanedUp = true;

        decor.removeEventListener('transitionend', onEnd);
        
        // Double requestAnimationFrame ensures the browser completely paints
        // the final transition frame before inline styles are cleared.
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            decor.style.position = 'absolute';
            decor.style.inset = decor.style.width = decor.style.height = decor.style.overflow = decor.style.zIndex = decor.style.margin = decor.style.transformOrigin = decor.style.transform = decor.style.borderRadius = decor.style.transition = '';
          });
        });
      }
      decor.addEventListener('transitionend', onEnd);
      isFull = false;
      savedRect = null;
    }
  })();
</script>
  <!-- Bottom decoration band -->
  <div class="hero-band" aria-hidden="true"></div>
</section>

<style>
  /* ── Morphing animations ── */

  @keyframes morph-blob {
    0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
    25% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
    50% { border-radius: 50% 60% 30% 60% / 40% 50% 50% 50%; }
    75% { border-radius: 60% 30% 50% 50% / 30% 60% 40% 70%; }
  }

  @keyframes color-drift {
    0% { filter: hue-rotate(0deg) saturate(1); }
    25% { filter: hue-rotate(90deg) saturate(1.2); }
    50% { filter: hue-rotate(180deg) saturate(1); }
    75% { filter: hue-rotate(270deg) saturate(1.1); }
    100% { filter: hue-rotate(360deg) saturate(1); }
  }

  @keyframes float-complex {
    0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
    25% { transform: translate(40px, -50px) rotate(5deg) scale(1.08); }
    50% { transform: translate(-20px, -90px) rotate(-3deg) scale(0.95); }
    75% { transform: translate(-50px, -30px) rotate(4deg) scale(1.03); }
  }

  @keyframes badge-shimmer {
    0% { background-position: 100% 0; }
    100% { background-position: 0% 0; }
  }
  .hero {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    position: relative;
    padding: 120px 0 80px;
    background: var(--white);
  }

  .hero-decor {
    position: absolute;
    inset: -20%;
    pointer-events: none;
    overflow: hidden;
    border-radius: 24px;
    opacity: 0;
    transition: opacity 1s ease-out;
  }
  
  .hero-decor.revealed {
    opacity: 1;
  }

  .hero-circle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.1;
  }

  /* ── Interactive Shapes Hover ── */
  .hero-circle,
  .hero-squiggle,
  .hero-zigzag,
  .hero-blob,
  .hero-grid,
  .hero-dots {
    cursor: pointer;
    pointer-events: auto;
    transition: scale 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                filter 0.3s ease, 
                opacity 0.3s ease;
  }

  .hero-circle:hover,
  .hero-circle.decor-active,
  .hero-squiggle:hover,
  .hero-squiggle.decor-active,
  .hero-zigzag:hover,
  .hero-zigzag.decor-active,
  .hero-blob:hover,
  .hero-blob.decor-active {
    scale: 1.18;
    opacity: 0.45 !important;
    filter: drop-shadow(8px 8px 0 rgba(0, 0, 0, 0.1)) saturate(1.3);
  }

  .hero-grid:hover,
  .hero-grid.decor-active,
  .hero-dots:hover,
  .hero-dots.decor-active {
    scale: 1.08;
    opacity: 0.3 !important;
  }

  .hero-circle--red {
    width: 300px;
    height: 300px;
    background: var(--red);
    top: -100px;
    right: -80px;
    animation: float-complex 16s ease-in-out infinite, color-drift 12s linear infinite;
    opacity: 0.12;
  }

  .hero-circle--blue {
    width: 180px;
    height: 180px;
    background: var(--blue);
    bottom: 10%;
    left: -60px;
    animation: float-complex 20s ease-in-out infinite reverse, color-drift 15s linear infinite reverse;
  }

  .hero-circle--yellow {
    width: 100px;
    height: 100px;
    background: var(--yellow);
    top: 30%;
    left: 15%;
    animation: float-complex 14s ease-in-out infinite, color-drift 8s linear infinite;
    opacity: 0.12;
  }

  .hero-squiggle {
    position: absolute;
    width: 180px;
    height: 50px;
    bottom: 200px;
    right: 10%;
    animation: squiggle-drift 8s ease-in-out infinite alternate, color-drift 6s linear infinite;
  }

  .hero-grid {
    position: absolute;
    width: 200px;
    height: 200px;
    right: 6%;
    bottom: 15%;
    background-image:
      linear-gradient(var(--black) 1px, transparent 1px),
      linear-gradient(90deg, var(--black) 1px, transparent 1px);
    background-size: 30px 30px;
    opacity: 0.04;
  }

  .hero-zigzag {
    position: absolute;
    width: 160px;
    height: 80px;
    top: 15%;
    left: 5%;
  }

  .hero-dots {
    position: absolute;
    width: 200px;
    height: 200px;
    bottom: 20%;
    right: 25%;
    background-image: radial-gradient(circle, var(--black) 2px, transparent 2px);
    background-size: 20px 20px;
    opacity: 0.06;
  }
  .hero-blob {
    position: absolute;
    width: 250px;
    height: 250px;
    background: linear-gradient(135deg, var(--pink), var(--yellow));
    opacity: 0.08;
    top: 60%;
    left: 60%;
    animation: morph-blob 14s ease-in-out infinite, float-complex 18s ease-in-out infinite, color-drift 10s linear infinite;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }
  
  .hero-reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .hero-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .typewriter-wrap {
    opacity: 0;
  }
  
  .typewriter-wrap.visible {
    opacity: 1;
  }
  
  .typewriter-cursor {
    display: inline-block;
    animation: typewriter-blink 0.8s step-end infinite;
    color: var(--black);
    font-weight: 700;
    margin-left: 2px;
  }
  
  @keyframes typewriter-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  

  .hero-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--black);
    padding: 6px 16px;
    margin-bottom: 24px;
  }
  #badge-text {
    background: linear-gradient(
      90deg,
      var(--white) 0%,
      var(--white) 30%,
      var(--yellow) 40%,
      var(--yellow) 55%,
      var(--white) 65%,
      var(--white) 100%
    );
    background-size: 300% 100%;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    animation: badge-shimmer 4s ease-in-out infinite;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 8vw, 5.5rem);
    line-height: 0.9;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 16px;
    cursor: pointer;
    user-select: none;
  }

  .hero-title-line {
    display: block;
    position: relative;
  }

  /* Stripe effect on part of the title */
  .hero-title-line::after {
    content: "";
    position: absolute;
    bottom: 8px;
    left: 0;
    width: 100%;
    height: 0.15em;
    background: repeating-linear-gradient(
      90deg,
      var(--yellow) 0px,
      var(--yellow) 20px,
      transparent 20px,
      transparent 30px
    );
    z-index: -1;
    opacity: 0.5;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.35rem);
    font-weight: 400;
    color: var(--black);
    opacity: 0.7;
    margin-bottom: 40px;
    max-width: 480px;
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                background 0.3s ease,
                color 0.3s ease,
                box-shadow 0.3s ease;
    border: 3px solid var(--black);
  }

  .btn--primary {
    background: var(--black);
    color: var(--white);
  }

  .btn--primary:hover {
    background: transparent;
    color: var(--black);
    transform: translate(-3px, -3px);
    box-shadow: 6px 6px 0 var(--yellow);
  }

  .btn--outline {
    background: transparent;
    color: var(--black);
  }

  .btn--outline:hover {
    background: var(--black);
    color: var(--white);
    transform: translate(-3px, -3px);
    box-shadow: 6px 6px 0 var(--pink);
  }

  .hero-band {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 12px;
    background: repeating-linear-gradient(
      90deg,
      var(--black) 0px,
      var(--black) 20px,
      var(--yellow) 20px,
      var(--yellow) 40px,
      var(--red) 40px,
      var(--red) 60px,
      var(--blue) 60px,
      var(--blue) 80px,
      var(--green) 80px,
      var(--green) 100px,
      var(--pink) 100px,
      var(--pink) 120px
    );
    background-size: 120px 12px;
    animation: hue-shift 4s steps(6) infinite;
  }

  @media (max-width: 992px) {
    .hero {
      padding: 80px 0 60px;
    }
  }

  @media (max-width: 768px) {
    .hero-decor {
      display: block !important;
      opacity: 1 !important;
      inset: 0 !important;
    }

    .hero-decor * {
      pointer-events: none !important; /* Lock clicks and touch states */
    }

    .hero-circle--red {
      width: 160px !important;
      height: 160px !important;
      top: -40px !important;
      right: -30px !important;
      opacity: 0.35 !important;
    }

    .hero-circle--blue {
      width: 110px !important;
      height: 110px !important;
      bottom: 8% !important;
      left: -30px !important;
      opacity: 0.35 !important;
    }

    .hero-circle--yellow {
      width: 60px !important;
      height: 60px !important;
      top: 25% !important;
      left: 5% !important;
      opacity: 0.35 !important;
    }

    .hero-squiggle {
      width: 100px !important;
      height: 30px !important;
      bottom: 15% !important;
      right: 5% !important;
      opacity: 0.40 !important;
    }

    .hero-zigzag {
      width: 90px !important;
      height: 45px !important;
      top: 15% !important;
      left: 2% !important;
      opacity: 0.40 !important;
    }

    .hero-dots {
      width: 120px !important;
      height: 120px !important;
      bottom: 25% !important;
      right: 15% !important;
      opacity: 0.18 !important;
    }

    .hero-blob {
      width: 160px !important;
      height: 160px !important;
      top: 55% !important;
      left: 45% !important;
      opacity: 0.18 !important;
    }

    .hero-grid {
      width: 120px !important;
      height: 120px !important;
      right: 2% !important;
      bottom: 8% !important;
      opacity: 0.18 !important;
    }
    
    .hero {
      padding: 60px 0;
    }

    .hero-subtitle {
      margin-bottom: 30px;
    }
  }

  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
      gap: 12px;
      width: 100%;
    }

    .btn {
      width: 100% !important;
      padding: 12px 24px;
      font-size: 0.85rem;
      text-align: center;
    }
  }
</style>
