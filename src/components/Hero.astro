---
// Hero with full Memphis retro treatment
const studioName = "XAKON.DEV";
const subtitle = "Web Development Studio";
---

<section class="hero">
  <div class="container">
    <!-- Decorative background elements -->
    <div class="hero-decor" aria-hidden="true">
      <div class="hero-circle hero-circle--red"></div>
      <div class="hero-circle hero-circle--blue"></div>
      <div class="hero-circle hero-circle--yellow"></div>

      <svg class="hero-squiggle" viewBox="0 0 300 50">
        <path
          d="M0 25 Q30 0 60 25 T120 25 T180 25 T240 25 T300 25"
          fill="none"
          stroke="var(--black)"
          stroke-width="3"
          opacity="0.1"
        />
      </svg>

      <div class="hero-grid"></div>

      <svg class="hero-zigzag" viewBox="0 0 200 80">
        <polyline
          points="0,80 25,0 50,80 75,0 100,80 125,0 150,80 175,0 200,80"
          fill="none"
          stroke="var(--red)"
          stroke-width="3"
          opacity="0.12"
        />
      </svg>

      <div class="hero-dots"></div>
      <div class="hero-blob" aria-hidden="true"></div>
    </div>

    <div class="hero-content fade-in">
      <div class="hero-badge">Portfolio</div>
      <h1 class="hero-title" id="theme-toggle-title">
        <span class="hero-title-line">{studioName}</span>
      </h1>
      <p class="hero-subtitle">{subtitle}</p>
      <div class="hero-actions">
        <a href="#projects" class="btn btn--primary">Проекты</a>
        <a href="#contact" class="btn btn--outline">Связаться</a>
      </div>
    </div>
  </div>

<script>
  const title = document.getElementById("theme-toggle-title");

  function getPreferredTheme() {
    const stored = localStorage.getItem("theme");
    if (stored) return stored;
    return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  }

  function setTheme(theme) {
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem("theme", theme);
  }

  const savedTheme = getPreferredTheme();
  setTheme(savedTheme);

  title.addEventListener("click", () => {
    const current = document.documentElement.getAttribute("data-theme");
    setTheme(current === "dark" ? "light" : "dark");
  });

  window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
    if (!localStorage.getItem("theme")) {
      setTheme(e.matches ? "dark" : "light");
    }
  });
</script>
  <!-- Bottom decoration band -->
  <div class="hero-band" aria-hidden="true"></div>
</section>

<style>
  /* ── Morphing animations ── */

  @keyframes morph-blob {
    0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
    25% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
    50% { border-radius: 50% 60% 30% 60% / 40% 50% 50% 50%; }
    75% { border-radius: 60% 30% 50% 50% / 30% 60% 40% 70%; }
  }

  @keyframes color-drift {
    0% { filter: hue-rotate(0deg) saturate(1); }
    25% { filter: hue-rotate(90deg) saturate(1.2); }
    50% { filter: hue-rotate(180deg) saturate(1); }
    75% { filter: hue-rotate(270deg) saturate(1.1); }
    100% { filter: hue-rotate(360deg) saturate(1); }
  }

  @keyframes float-complex {
    0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
    25% { transform: translate(40px, -50px) rotate(5deg) scale(1.08); }
    50% { transform: translate(-20px, -90px) rotate(-3deg) scale(0.95); }
    75% { transform: translate(-50px, -30px) rotate(4deg) scale(1.03); }
  }

  @keyframes title-reveal {
    0% { letter-spacing: -0.15em; opacity: 0; }
    40% { opacity: 0.4; }
    100% { letter-spacing: -0.03em; opacity: 1; }
  }
  .hero {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    position: relative;
    padding: 120px 0 80px;
    background: var(--white);
  }

  .hero-decor {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    transform: scale(1.4);

    border-radius: 24px;
  }

  .hero-circle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.1;
  }

  .hero-circle--red {
    width: 300px;
    height: 300px;
    background: var(--red);
    top: -100px;
    right: -80px;
    animation: float-complex 16s ease-in-out infinite, color-drift 12s linear infinite;
    opacity: 0.12;
  }

  .hero-circle--blue {
    width: 180px;
    height: 180px;
    background: var(--blue);
    bottom: 10%;
    left: -60px;
    animation: float-complex 20s ease-in-out infinite reverse, color-drift 15s linear infinite reverse;
  }

  .hero-circle--yellow {
    width: 100px;
    height: 100px;
    background: var(--yellow);
    top: 30%;
    left: 15%;
    animation: float-complex 14s ease-in-out infinite, color-drift 8s linear infinite;
    opacity: 0.12;
  }

  .hero-squiggle {
    position: absolute;
    width: 300px;
    height: 50px;
    bottom: 200px;
    right: 10%;
    animation: squiggle-drift 8s ease-in-out infinite alternate, color-drift 6s linear infinite;
  }

  .hero-grid {
    position: absolute;
    width: 200px;
    height: 200px;
    right: 6%;
    bottom: 15%;
    background-image:
      linear-gradient(var(--black) 1px, transparent 1px),
      linear-gradient(90deg, var(--black) 1px, transparent 1px);
    background-size: 30px 30px;
    opacity: 0.04;
  }

  .hero-zigzag {
    position: absolute;
    width: 160px;
    height: 80px;
    top: 15%;
    left: 5%;
  }

  .hero-dots {
    position: absolute;
    width: 200px;
    height: 200px;
    bottom: 20%;
    right: 25%;
    background-image: radial-gradient(circle, var(--black) 2px, transparent 2px);
    background-size: 20px 20px;
    opacity: 0.06;
  }
  .hero-blob {
    position: absolute;
    width: 250px;
    height: 250px;
    background: linear-gradient(135deg, var(--pink), var(--yellow));
    opacity: 0.08;
    top: 60%;
    left: 60%;
    animation: morph-blob 14s ease-in-out infinite, float-complex 18s ease-in-out infinite, color-drift 10s linear infinite;
    filter: blur(30px);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--black);
    padding: 6px 16px;
    margin-bottom: 24px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 8vw, 5.5rem);
    line-height: 0.9;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 16px;
    cursor: pointer;
    user-select: none;
    animation: title-reveal 1.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-title-line {
    display: block;
    position: relative;
  }

  /* Stripe effect on part of the title */
  .hero-title-line::after {
    content: "";
    position: absolute;
    bottom: 8px;
    left: 0;
    width: 100%;
    height: 0.15em;
    background: repeating-linear-gradient(
      90deg,
      var(--yellow) 0px,
      var(--yellow) 20px,
      transparent 20px,
      transparent 30px
    );
    z-index: -1;
    opacity: 0.5;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.35rem);
    font-weight: 400;
    color: var(--black);
    opacity: 0.7;
    margin-bottom: 40px;
    max-width: 480px;
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 3px solid var(--black);
  }

  .btn--primary {
    background: var(--black);
    color: var(--white);
  }

  .btn--primary:hover {
    background: transparent;
    color: var(--black);
    transform: translate(-3px, -3px);
    box-shadow: 6px 6px 0 var(--yellow);
  }

  .btn--outline {
    background: transparent;
    color: var(--black);
  }

  .btn--outline:hover {
    background: var(--black);
    color: var(--white);
    transform: translate(-3px, -3px);
    box-shadow: 6px 6px 0 var(--pink);
  }

  .hero-band {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 12px;
    background: repeating-linear-gradient(
      90deg,
      var(--black) 0px,
      var(--black) 20px,
      var(--yellow) 20px,
      var(--yellow) 40px,
      var(--red) 40px,
      var(--red) 60px,
      var(--blue) 60px,
      var(--blue) 80px,
      var(--green) 80px,
      var(--green) 100px,
      var(--pink) 100px,
      var(--pink) 120px
    );
    background-size: 120px 12px;
    animation: hue-shift 4s steps(6) infinite;
  }
</style>
